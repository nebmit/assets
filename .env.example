# Postgres connection for the app and worker
DATABASE_URL=postgres://assets:assets@localhost:5432/assets

# Directory where raw source payloads are archived (created if missing)
RAW_DATA_DIR=./data/raw

# Cron expression for the daily pre-market batch (worker `schedule` command)
INGEST_CRON=30 6 * * *

# IANA timezone the cron expression is evaluated in
TZ=Europe/Berlin
