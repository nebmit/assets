# Postgres connection for the app and worker
DATABASE_URL=postgres://assets:assets@localhost:5432/assets

# Directory where raw source payloads are archived (created if missing)
RAW_DATA_DIR=./data/raw

# Days of raw archives to keep; the worker prunes older date directories
# after each full run. Leave unset to keep everything forever.
#RAW_RETENTION_DAYS=30

# Cron expression for the daily pre-market batch (worker `schedule` command)
INGEST_CRON=30 6 * * *

# IANA timezone the cron expression is evaluated in
TZ=Europe/Berlin

# Behind a reverse proxy, tell adapter-node which header carries the real
# client IP — the /mcp rate limiter keys on it (see adapter-node docs)
#ADDRESS_HEADER=X-Forwarded-For
#XFF_DEPTH=1

# --- SSO / OAuth (timben.net) ---
# Origin of the SSO host / OAuth authorization server
AUTH_ORIGIN=http://localhost:5172
# This server's canonical resource identifier — the audience access tokens
# must be bound to (prod: https://assets.timben.net/mcp)
RESOURCE_URL=http://localhost:5173/mcp
# Shared secret for the authorization server's introspection endpoint; must
# match core.timben's INTROSPECTION_SECRET. Generate: openssl rand -hex 32
# Empty means every /mcp request is rejected (fails closed).
INTROSPECTION_SECRET=
